{
  "name": "openbutler-desktop",
  "version": "0.1.4",
  "private": true,
  "description": "OpenButler Windows desktop shell",
  "main": "src/main.cjs",
  "scripts": {
    "dev": "electron .",
    "build:frontend": "node scripts/build-frontend-for-desktop.mjs",
    "build:backend": "pyinstaller --noconfirm desktop_backend.spec",
    "pack": "npm run build:frontend && electron-builder --dir",
    "dist": "node scripts/build-installer.mjs",
    "check": "node scripts/check-desktop-contract.mjs",
    "smoke:packaged": "node scripts/smoke-packaged-app.mjs",
    "check:frontend-assets": "node scripts/check-desktop-frontend-assets.mjs"
  },
  "build": {
    "appId": "moe.giftia.openbutler",
    "productName": "OpenButler",
    "asar": true,
    "files": [
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      },
      {
        "from": "../frontend/dist",
        "to": "frontend/dist"
      },
      {
        "from": "dist/openbutler-backend.exe",
        "to": "backend/openbutler-backend.exe"
      }
    ],
    "win": {
      "icon": "assets/openbutler.ico",
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ],
      "artifactName": "OpenButler-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "include": "installer/installer.nsh",
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  }
}
